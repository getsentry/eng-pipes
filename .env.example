# direnv will make a copy of this file as an .env file
# Follow the instructions in README.md as how to add your personal
# tokens and secrets in this file

# GitHub
GH_USER_TOKEN=''
GH_WEBHOOK_SECRET=''
GH_APP_PRIVATE_KEY='-----BEGIN RSA PRIVATE KEY----------END RSA PRIVATE KEY-----'
GH_ORGS_YML='github-orgs.local.yml'

# Slack
SLACK_SIGNING_SECRET=''
SLACK_BOT_USER_ACCESS_TOKEN=''

# Webhook secrets
GOCD_WEBHOOK_SECRET=''
KAFKA_CONTROL_PLANE_WEBHOOK_SECRET=''
SENTRY_OPTIONS_WEBHOOK_SECRET=''
SENTRY_INFORMER_WEBHOOK_SECRET=''

# BigQuery — GitHub→email directory (SEC-1508). Leave unset for now;
# placeholders in src/config/index.ts let the build pass, but the sync job
# will only do real work once the dataset/table land.
GITHUB_USER_DIRECTORY_BQ_DATASET=''
GITHUB_USER_DIRECTORY_BQ_TABLE=''

# Silence some GCP noise
DRY_RUN=true
